RewriteEngine On

# 1. Redirigir index.php a la raíz (evita duplicidad de contenido)
RewriteCond %{THE_REQUEST} ^[A-Z]{3,}\s([^?]*\/)?index\.php [NC]
RewriteRule ^(.*)index\.php$ %1 [R=301,L]

# 2. Redirigir accesos directos a archivos .php a su versión sin extensión
RewriteCond %{THE_REQUEST} ^[A-Z]{3,}\s([^.]+)\.php [NC]
RewriteRule ^ %1 [R=301,L]

# 3. Reescribir de forma transparente las URLs amigables a sus archivos .php correspondientes
RewriteCond %{REQUEST_FILENAME} !-d
RewriteCond %{REQUEST_FILENAME}.php -f
RewriteRule ^(.*?)/?$ $1.php [L]
